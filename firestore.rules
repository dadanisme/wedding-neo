rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Guests — dashboard reads require authentication.
    // All writes go through Admin SDK (bypasses rules).
    match /guests/{guestId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Wishes — publicly readable (invitation page live feed).
    // All writes go through Admin SDK (bypasses rules).
    match /wishes/{wishId} {
      allow read: if true;
      allow write: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
